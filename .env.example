# ============================================================
# 数字人对接中转服务 - 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================================

# Dify 服务地址（必填）
# 例如：https://atwdify.antiwearvalve.com/v1
DIFY_URL=https://your-dify-domain.com/v1

# Dify API 密钥（必填）
# 例如：app-PDkSHiHZsZIluoZF7N2OlNZM
DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxx

# 服务端口（可选，默认为 8000）
DH_PORT=8000

# Redis 暴露配置（可选，默认为空 = 不暴露）
# 设置非空值时启用 docker-compose.redis-expose.yml 覆盖配置
#   示例：REDIS_EXPOSE_PORT=6379
# 通常不需要设置，Redis 默认仅在容器网络内部可用
# REDIS_EXPOSE_PORT=6379
